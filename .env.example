# Get a free key at console.groq.com -> API Keys (no card required).
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Firestore persistence (server-side only — never exposed to the browser).
# Create a service account in the Firebase console:
#   Project settings -> Service accounts -> Generate new private key.
# Paste the entire downloaded JSON on one line as the value below.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com"}
